GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
TO_EMAIL=you@gmail.com

# Optional but recommended — raises GitHub rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Comma-separated list of languages to filter trending repos. Leave blank for all.
LANGUAGES=Python,JavaScript,TypeScript

# Hacker News: minimum score for a story to be included
HN_MIN_SCORE=50

# GitHub issues: minimum number of comments to be considered "hot"
ISSUE_MIN_COMMENTS=5
